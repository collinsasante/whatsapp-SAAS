enum SubscriptionStatus {
  TRIAL
  ACTIVE
  PAST_DUE
  SUSPENDED
  CANCELED
  EXPIRED
}

enum BillingCycle {
  MONTHLY
  YEARLY
}

enum PaymentGateway {
  STRIPE
  PAYSTACK
}

enum PaymentStatus {
  PENDING
  SUCCEEDED
  FAILED
  REFUNDED
  DISPUTED
}

enum InvoiceStatus {
  DRAFT
  OPEN
  PAID
  VOID
  UNCOLLECTIBLE
}

model Plan {
  id          String  @id @default(uuid())
  slug        String  @unique
  name        String
  description String?
  monthlyPrice Float  @map("monthly_price")
  yearlyPrice  Float  @map("yearly_price")
  currency     String @default("USD")
  ghsMonthlyPrice Float? @map("ghs_monthly_price")
  ghsYearlyPrice  Float? @map("ghs_yearly_price")
  isActive     Boolean @default(true) @map("is_active")
  isPublic     Boolean @default(true) @map("is_public")
  trialDays    Int     @default(0)    @map("trial_days")

  limMaxAgents         Int @default(1)    @map("lim_max_agents")
  limMaxChannels       Int @default(1)    @map("lim_max_channels")
  limMaxContacts       Int @default(500)  @map("lim_max_contacts")
  limMaxTemplates      Int @default(5)    @map("lim_max_templates")
  limMessagesPerMonth  Int @default(1000) @map("lim_messages_per_month")
  limMaxCampaigns      Int @default(0)    @map("lim_max_campaigns")
  limAiCreditsPerMonth Int @default(0)    @map("lim_ai_credits_per_month")
  limStorageGb         Int @default(1)    @map("lim_storage_gb")

  features  Json @default("[]")
  metadata  Json?
  sortOrder Int  @default(0) @map("sort_order")

  stripePriceIdMonthly   String? @unique @map("stripe_price_id_monthly")
  stripePriceIdYearly    String? @unique @map("stripe_price_id_yearly")
  paystackPlanCodeMonthly String? @unique @map("paystack_plan_code_monthly")
  paystackPlanCodeYearly  String? @unique @map("paystack_plan_code_yearly")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt      @map("updated_at")

  subscriptions Subscription[]

  @@map("billing_plans")
}

model Subscription {
  id       String             @id @default(uuid())
  tenantId String             @unique @map("tenant_id")
  planId   String             @map("plan_id")
  status   SubscriptionStatus @default(TRIAL)
  cycle    BillingCycle       @default(MONTHLY)

  trialEndsAt        DateTime? @map("trial_ends_at")
  currentPeriodStart DateTime  @map("current_period_start")
  currentPeriodEnd   DateTime  @map("current_period_end")
  cancelAtPeriodEnd  Boolean   @default(false) @map("cancel_at_period_end")
  canceledAt         DateTime? @map("canceled_at")

  stripeSubscriptionId      String? @unique @map("stripe_subscription_id")
  paystackSubscriptionCode  String? @unique @map("paystack_subscription_code")
  gatewayCustomerId         String? @map("gateway_customer_id")

  metadata  Json?
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt      @map("updated_at")

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  plan   Plan   @relation(fields: [planId], references: [id])

  @@index([status])
  @@index([currentPeriodEnd])
  @@map("subscriptions")
}

model Invoice {
  id            String        @id @default(uuid())
  tenantId      String        @map("tenant_id")
  invoiceNumber String        @unique @map("invoice_number")
  status        InvoiceStatus @default(DRAFT)

  subtotal Float
  tax      Float @default(0)
  discount Float @default(0)
  total    Float
  currency String @default("USD")

  billingPeriodStart DateTime  @map("billing_period_start")
  billingPeriodEnd   DateTime  @map("billing_period_end")
  dueDate            DateTime  @map("due_date")
  paidAt             DateTime? @map("paid_at")

  billingEmail String? @map("billing_email")
  billingName  String? @map("billing_name")

  gateway           PaymentGateway? @map("gateway")
  gatewayInvoiceId  String?         @map("gateway_invoice_id")
  gatewayPaymentUrl String?         @map("gateway_payment_url")

  notes     String?
  metadata  Json?
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt      @map("updated_at")

  tenant   Tenant        @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  items    InvoiceItem[]
  payments Payment[]

  @@index([tenantId])
  @@index([status])
  @@index([createdAt])
  @@map("invoices")
}

model InvoiceItem {
  id          String @id @default(uuid())
  invoiceId   String @map("invoice_id")
  description String
  quantity    Int    @default(1)
  unitPrice   Float  @map("unit_price")
  amount      Float
  metadata    Json?

  invoice Invoice @relation(fields: [invoiceId], references: [id], onDelete: Cascade)

  @@index([invoiceId])
  @@map("invoice_items")
}

model Payment {
  id        String         @id @default(uuid())
  tenantId  String         @map("tenant_id")
  invoiceId String?        @map("invoice_id")
  gateway   PaymentGateway
  status    PaymentStatus  @default(PENDING)

  amount   Float
  currency String @default("USD")

  gatewayPaymentId   String? @unique @map("gateway_payment_id")
  gatewayReference   String? @map("gateway_reference")
  gatewayWebhookData Json?   @map("gateway_webhook_data")

  verifiedAt DateTime? @map("verified_at")
  failReason String?   @map("fail_reason")

  metadata  Json?
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt      @map("updated_at")

  tenant  Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  invoice Invoice? @relation(fields: [invoiceId], references: [id], onDelete: SetNull)

  @@index([tenantId])
  @@index([status])
  @@index([gateway])
  @@map("payments")
}

model WorkspaceUsage {
  id       String @id @default(uuid())
  tenantId String @map("tenant_id")

  periodStart DateTime @map("period_start")
  periodEnd   DateTime @map("period_end")

  messagesSent        Int   @default(0)   @map("messages_sent")
  messagesReceived    Int   @default(0)   @map("messages_received")
  conversationsOpened Int   @default(0)   @map("conversations_opened")
  campaignsSent       Int   @default(0)   @map("campaigns_sent")
  aiCreditsUsed       Int   @default(0)   @map("ai_credits_used")
  activeAgents        Int   @default(0)   @map("active_agents")
  activeChannels      Int   @default(0)   @map("active_channels")
  storageUsedMb       Float @default(0)   @map("storage_used_mb")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt      @map("updated_at")

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([tenantId, periodStart])
  @@index([tenantId])
  @@map("workspace_usage")
}

model BillingEvent {
  id       String @id @default(uuid())
  tenantId String @map("tenant_id")

  event          String
  gateway        PaymentGateway? @map("gateway")
  gatewayEventId String?         @map("gateway_event_id")

  data      Json
  processed Boolean  @default(false)
  error     String?

  createdAt DateTime @default(now()) @map("created_at")

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([event])
  @@index([processed])
  @@map("billing_events")
}

model PromoCode {
  id          String  @id @default(uuid())
  code        String  @unique
  description String?

  discountType  String @map("discount_type")
  discountValue Float  @map("discount_value")
  currency      String @default("USD")

  maxUses   Int? @map("max_uses")
  usedCount Int  @default(0) @map("used_count")

  validFrom  DateTime? @map("valid_from")
  validUntil DateTime? @map("valid_until")

  applicablePlans Json?    @map("applicable_plans")
  isActive        Boolean  @default(true) @map("is_active")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt      @map("updated_at")

  usages PromoCodeUsage[]

  @@map("promo_codes")
}

model PromoCodeUsage {
  id          String @id @default(uuid())
  promoCodeId String @map("promo_code_id")
  tenantId    String @map("tenant_id")
  invoiceId   String? @map("invoice_id")

  discountApplied Float    @map("discount_applied")
  usedAt          DateTime @default(now()) @map("used_at")

  promoCode PromoCode @relation(fields: [promoCodeId], references: [id], onDelete: Cascade)

  @@unique([promoCodeId, tenantId])
  @@index([tenantId])
  @@map("promo_code_usages")
}

model CreditPurchase {
  id          String        @id @default(uuid())
  tenantId    String        @map("tenant_id")
  credits     Int
  packSlug    String        @map("pack_slug")
  amount      Float
  currency    String        @default("USD")
  gateway     PaymentGateway? @map("gateway")
  paystackRef String?       @unique @map("paystack_ref")
  status      PaymentStatus @default(PENDING)
  createdAt   DateTime      @default(now()) @map("created_at")
  updatedAt   DateTime      @updatedAt      @map("updated_at")

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@map("credit_purchases")
}

// ── Feedback ─────────────────────────────────────────────────────────────────

model Feedback {
  id       String         @id @default(uuid())
  tenantId String         @map("tenant_id")
  userId   String?        @map("user_id")
  type     FeedbackType
  subject  String?
  body     String
  rating   Int?
  page     String?
  status   FeedbackStatus @default(NEW)

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt      @map("updated_at")

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  user   User?  @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([tenantId])
  @@index([type])
  @@index([status])
  @@map("feedback")
}

enum FeedbackType {
  BUG
  FEATURE_REQUEST
  GENERAL
  BILLING
}

enum FeedbackStatus {
  NEW
  REVIEWED
  IN_PROGRESS
  RESOLVED
  DISMISSED
}

model KnowledgeBaseArticle {
  id        String   @id @default(uuid())
  tenantId  String   @map("tenant_id")
  title     String
  content   String
  source    String   @default("manual") // manual | learned | upload | url
  sourceRef String?  @map("source_ref")  // filename or URL
  isActive  Boolean  @default(true) @map("is_active")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@map("knowledge_base_articles")
}

model DemoRequest {
  id              String   @id @default(cuid())
  fullName        String   @map("full_name")
  workEmail       String   @map("work_email")
  phoneNumber     String?  @map("phone_number")
  businessName    String   @map("business_name")
  businessType    String   @map("business_type")
  companySize     String   @map("company_size")
  currentPlatform String?  @map("current_platform")
  preferredDate   DateTime @map("preferred_date")
  preferredTime   String   @map("preferred_time")
  timezone        String   @default("UTC")
  goals           String?
  leadScore       Int      @default(0) @map("lead_score")
  leadTier        String   @default("standard") @map("lead_tier")
  priority        Int      @default(1)
  status          String   @default("new")
  notes           LeadNote[]
  statusHistory   LeadStatusHistory[]
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  @@index([status])
  @@index([workEmail])
  @@index([leadScore])
  @@map("demo_requests")
}

model LeadNote {
  id            String      @id @default(cuid())
  demoRequestId String      @map("demo_request_id")
  demoRequest   DemoRequest @relation(fields: [demoRequestId], references: [id], onDelete: Cascade)
  content       String
  authorName    String?     @map("author_name")
  createdAt     DateTime    @default(now()) @map("created_at")

  @@index([demoRequestId])
  @@map("lead_notes")
}

model LeadStatusHistory {
  id            String      @id @default(cuid())
  demoRequestId String      @map("demo_request_id")
  demoRequest   DemoRequest @relation(fields: [demoRequestId], references: [id], onDelete: Cascade)
  fromStatus    String?     @map("from_status")
  toStatus      String      @map("to_status")
  changedBy     String?     @map("changed_by")
  createdAt     DateTime    @default(now()) @map("created_at")

  @@index([demoRequestId])
  @@map("lead_status_history")
}

model FeatureFlag {
  id          String   @id @default(cuid())
  key         String   @unique
  name        String
  description String?
  enabled     Boolean  @default(false)
  rolloutType String   @default("all") // all | percentage | tenants | beta
  rolloutPct  Int      @default(100) @map("rollout_pct")
  betaTenants String[] @map("beta_tenants")
  environment String   @default("all")
  killSwitch  Boolean  @default(false) @map("kill_switch")
  category    String?
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  rollouts FeatureFlagRollout[]

  @@map("feature_flags")
}

model FeatureFlagRollout {
  id        String   @id @default(cuid())
  flagId    String   @map("flag_id")
  tenantId  String   @map("tenant_id")
  enabled   Boolean  @default(true)
  createdAt DateTime @default(now()) @map("created_at")

  flag   FeatureFlag @relation(fields: [flagId], references: [id], onDelete: Cascade)
  tenant Tenant      @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([flagId, tenantId])
  @@index([tenantId])
  @@map("feature_flag_rollouts")
}

model AppVersion {
  id          String    @id @default(cuid())
  version     String    @unique
  major       Int
  minor       Int
  patch       Int
  channel     String    @default("stable")
  releasedAt  DateTime  @default(now()) @map("released_at")
  description String?
  changelog   Json?
  isLatest    Boolean   @default(false) @map("is_latest")

  deployments DeploymentLog[]

  @@map("app_versions")
}

model DeploymentLog {
  id            String    @id @default(cuid())
  versionId     String?   @map("version_id")
  version       String
  commitHash    String?   @map("commit_hash")
  branch        String?
  environment   String    @default("production")
  deployedBy    String?   @map("deployed_by")
  status        String    @default("success")
  startedAt     DateTime  @default(now()) @map("started_at")
  finishedAt    DateTime? @map("finished_at")
  notes         String?
  buildDuration Int?      @map("build_duration")

  appVersion AppVersion? @relation(fields: [versionId], references: [id])

  @@index([environment])
  @@index([startedAt])
  @@map("deployment_logs")
}

model AiInteractionLog {
  id               String   @id @default(uuid())
  tenantId         String   @map("tenant_id")
  conversationId   String   @map("conversation_id")
  contactId        String?  @map("contact_id")
  customerMessage  String   @map("customer_message") @db.Text
  aiResponse       String   @map("ai_response") @db.Text
  finalSentMessage String?  @map("final_sent_message") @db.Text
  editedByAgent    Boolean  @default(false) @map("edited_by_agent")
  agentId          String?  @map("agent_id")
  status           String   @default("SUGGESTED") @map("status")
  confidenceScore  Float?   @map("confidence_score")
  responseTimeMs   Int?     @map("response_time_ms")
  feedbackRating   Int?     @map("feedback_rating")
  feedbackLabel    String?  @map("feedback_label")
  feedbackNote     String?  @map("feedback_note")
  createdAt        DateTime @default(now()) @map("created_at")

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([conversationId])
  @@index([tenantId, createdAt])
  @@map("ai_interaction_logs")
}
