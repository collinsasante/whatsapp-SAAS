generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Tenant {
  id                 String          @id @default(uuid())
  name               String
  phoneNumberId      String?         @map("phone_number_id")
  wabaId             String?         @map("waba_id")
  accessToken        String?         @map("access_token")
  webhookVerifyToken String          @map("webhook_verify_token")
  plan                    String   @default("free")
  planStartedAt           DateTime? @map("plan_started_at")
  planExpiresAt           DateTime? @map("plan_expires_at")
  billingEmail            String?  @map("billing_email")
  aiCredits               Int      @default(0) @map("ai_credits")
  isActive                Boolean  @default(true)        @map("is_active")
  onboardingCompleted     Boolean  @default(false)       @map("onboarding_completed")
  onboardingStep          Int      @default(0)           @map("onboarding_step")
  industry                String?
  teamSize                String?  @map("team_size")
  country                 String?
  logoUrl                 String?  @map("logo_url")
  businessCategory        String?  @map("business_category")
  businessDescription     String?  @map("business_description")
  businessAddress         String?  @map("business_address")
  businessWebsite         String?  @map("business_website")
  createdAt               DateTime @default(now()) @map("created_at")
  updatedAt               DateTime @updatedAt     @map("updated_at")

  users               User[]
  contacts            Contact[]
  conversations       Conversation[]
  messages            Message[]
  templates           Template[]
  campaigns           Campaign[]
  automationRules     AutomationRule[]
  mediaAssets         MediaAsset[]
  auditLogs           AuditLog[]
  settings            TenantSettings?
  channels            Channel[]
  activityLogs        ActivityLog[]
  messageReactions    MessageReaction[]
  pinnedMessages      PinnedMessage[]
  callLogs            CallLog[]
  notifications       Notification[]
  cannedResponses          CannedResponse[]
  cannedResponseCategories CannedResponseCategory[]
  cannedResponseUsages     CannedResponseUsage[]
  apiKeys                  ApiKey[]
  publicApiLogs            PublicApiLog[]
  chatbotFlows        ChatbotFlow[]
  tags                Tag[]
  contactAttributes   ContactAttribute[]
  webhooks            Webhook[]
  contactSegments     ContactSegment[]
  billingInvoices     BillingInvoice[]
  subscription        Subscription?
  invoices            Invoice[]
  payments            Payment[]
  workspaceUsages     WorkspaceUsage[]
  billingEvents       BillingEvent[]
  teams               Team[]
  conversationEvents  ConversationEvent[]
  workspaceMembers    WorkspaceMember[]   @relation("WorkspaceMembers")
  knowledgeBase       KnowledgeBaseArticle[]
  workspaceInvitations WorkspaceInvitation[] @relation("WorkspaceInvitations")
  messageDeletions     MessageDeletion[]
  feedback             Feedback[]
  featureFlagRollouts  FeatureFlagRollout[]
  whatsappNumbers      WhatsAppNumber[]
  creditPurchases     CreditPurchase[]
  aiInteractionLogs   AiInteractionLog[]

  @@map("tenants")
}

model WhatsAppNumber {
  id            String   @id @default(uuid())
  tenantId      String   @map("tenant_id")
  label         String
  phoneNumberId String   @map("phone_number_id")
  wabaId        String   @map("waba_id")
  accessToken   String   @map("access_token")
  isDefault     Boolean  @default(false) @map("is_default")
  isActive      Boolean  @default(true)  @map("is_active")
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt      @map("updated_at")

  tenant        Tenant         @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  conversations Conversation[]

  @@unique([tenantId, phoneNumberId])
  @@index([tenantId])
  @@map("whatsapp_numbers")
}

model Team {
  id          String   @id @default(uuid())
  tenantId    String   @map("tenant_id")
  name        String
  description String?
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  tenant  Tenant       @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  members TeamMember[]

  @@index([tenantId])
  @@map("teams")
}

model TeamMember {
  id        String   @id @default(uuid())
  teamId    String   @map("team_id")
  userId    String   @map("user_id")
  createdAt DateTime @default(now()) @map("created_at")

  team Team @relation(fields: [teamId], references: [id], onDelete: Cascade)

  @@unique([teamId, userId])
  @@map("team_members")
}

model BillingInvoice {
  id          String    @id @default(uuid())
  tenantId    String    @map("tenant_id")
  amount      Float
  currency    String    @default("USD")
  status      String    @default("PAID")
  description String
  period      String
  paidAt      DateTime? @map("paid_at")
  createdAt   DateTime  @default(now()) @map("created_at")

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@map("billing_invoices")
}

model TenantSettings {
  id                  String   @id @default(uuid())
  tenantId            String   @unique @map("tenant_id")
  businessName        String?  @map("business_name")
  businessEmail       String?  @map("business_email")
  businessPhone       String?  @map("business_phone")
  businessAddress     String?  @map("business_address")
  businessWebsite     String?  @map("business_website")
  businessDescription String?  @map("business_description")
  timezone            String   @default("UTC")
  autoReply           Boolean  @default(false) @map("auto_reply")
  autoReplyMessage    String?  @map("auto_reply_message")
  maxAgents           Int      @default(10) @map("max_agents")
  welcomeEnabled      Boolean  @default(false) @map("welcome_enabled")
  welcomeMessage      String?  @map("welcome_message")
  offHoursEnabled     Boolean  @default(false) @map("off_hours_enabled")
  offHoursMessage     String?  @map("off_hours_message")
  offHoursSchedule    Json     @default("{}") @map("off_hours_schedule")
  optOutKeywords      String[] @default(["STOP", "UNSUBSCRIBE"]) @map("opt_out_keywords")
  optInKeywords       String[] @default(["START", "SUBSCRIBE"]) @map("opt_in_keywords")
  optOutReply         String?  @map("opt_out_reply")
  optInReply          String?  @map("opt_in_reply")
  widgetEnabled       Boolean  @default(false) @map("widget_enabled")
  widgetConfig        Json     @default("{}") @map("widget_config")
  aiEnabled           Boolean  @default(false) @map("ai_enabled")
  aiAlwaysOn          Boolean  @default(false) @map("ai_always_on")
  aiPersonality       String?  @map("ai_personality")
  aiMode              String   @default("SUGGESTION") @map("ai_mode") // SUGGESTION | AUTO_REPLY
  aiPilotGroup        Boolean  @default(false) @map("ai_pilot_group")
  aiTrialStartedAt    DateTime? @map("ai_trial_started_at")
  aiTrialApprovedAt   DateTime? @map("ai_trial_approved_at")
  airtableEnabled     Boolean  @default(false) @map("airtable_enabled")
  airtableApiKey      String?  @map("airtable_api_key")
  airtableBaseId      String?  @map("airtable_base_id")
  airtableTableName   String?  @map("airtable_table_name")
  updatedAt           DateTime @updatedAt @map("updated_at")

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@map("tenant_settings")
}

model User {
  id           String    @id @default(uuid())
  tenantId     String    @map("tenant_id")
  email        String
  passwordHash String    @map("password_hash")
  name         String
  role         UserRole  @default(AGENT)
  avatarUrl    String?   @map("avatar_url")
  phone        String?
  isActive     Boolean   @default(true) @map("is_active")
  isAiAgent    Boolean   @default(false) @map("is_ai_agent")
  lastSeenAt           DateTime? @map("last_seen_at")
  lastLoginAt          DateTime? @map("last_login_at")
  refreshToken         String?   @map("refresh_token")
  emailVerified        Boolean   @default(false) @map("email_verified")
  emailVerifyToken     String?   @map("email_verify_token")
  emailVerifyExpiry    DateTime? @map("email_verify_expiry")
  twoFactorCode        String?   @map("two_factor_code")
  twoFactorCodeExpiry  DateTime? @map("two_factor_code_expiry")
  loginPin             String?   @map("login_pin")
  createdAt            DateTime  @default(now()) @map("created_at")
  updatedAt            DateTime  @updatedAt @map("updated_at")

  tenant                Tenant            @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  assignedConversations Conversation[]    @relation("AssignedAgent")
  sentMessages          Message[]         @relation("MessageSender")
  notes                 ConversationNote[]
  campaigns             Campaign[]        @relation("CampaignCreator")
  mediaAssets           MediaAsset[]
  auditLogs             AuditLog[]
  activityLogs          ActivityLog[]
  messageReactions      MessageReaction[]
  pinnedMessages        PinnedMessage[]   @relation("PinnedBy")
  callLogs              CallLog[]
  callNotes             CallNote[]
  notifications         Notification[]
  cannedResponses          CannedResponse[]
  favoriteResponses        UserFavoriteResponse[]
  cannedResponseUsages     CannedResponseUsage[]
  apiKeys                  ApiKey[]
  workspaceMemberships  WorkspaceMember[] @relation("WorkspaceMemberships")
  invitedMembers        WorkspaceMember[] @relation("InvitedMembers")
  sentInvitations       WorkspaceInvitation[] @relation("SentInvitations")
  messageEdits          MessageEdit[]
  messageDeletions      MessageDeletion[]
  feedback              Feedback[]

  @@unique([tenantId, email])
  @@index([tenantId])
  @@index([email])
  @@map("users")
}

enum UserRole {
  SUPER_ADMIN
  ADMIN
  AGENT
  VIEWER
}

model Contact {
  id           String   @id @default(uuid())
  tenantId     String   @map("tenant_id")
  phone        String
  name         String?
  email        String?
  avatarUrl    String?  @map("avatar_url")
  labels       String[] @default([])
  customFields Json     @default("{}") @map("custom_fields")
  isBlocked    Boolean  @default(false) @map("is_blocked")
  optedOut     Boolean  @default(false) @map("opted_out")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  tenant             Tenant              @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  conversations      Conversation[]
  messages           Message[]
  campaignRecipients CampaignRecipient[]
  activityLogs       ActivityLog[]
  callLogs           CallLog[]

  @@unique([tenantId, phone])
  @@index([tenantId])
  @@index([phone])
  @@map("contacts")
}

model Conversation {
  id                String             @id @default(uuid())
  tenantId          String             @map("tenant_id")
  contactId         String             @map("contact_id")
  assignedToId      String?            @map("assigned_to_id")
  resolvedById      String?            @map("resolved_by_id")
  channelId         String?            @map("channel_id")
  whatsappNumberId  String?            @map("whatsapp_number_id")
  status         ConversationStatus @default(OPEN)
  priority       Int                @default(0)
  unreadCount    Int                @default(0) @map("unread_count")
  reopenedCount  Int                @default(0) @map("reopened_count")
  lastMessageAt  DateTime?          @map("last_message_at")
  snoozedUntil   DateTime?          @map("snoozed_until")
  requestedAt    DateTime?          @map("requested_at")
  intervenedAt   DateTime?          @map("intervened_at")
  resolvedAt     DateTime?          @map("resolved_at")
  reopenedAt     DateTime?          @map("reopened_at")
  slaDeadline    DateTime?          @map("sla_deadline")
  slaBreached    Boolean            @default(false) @map("sla_breached")
  csatScore      Int?               @map("csat_score")
  csatComment    String?            @map("csat_comment")
  csatSubmittedAt DateTime?         @map("csat_submitted_at")
  labels         String[]           @default([])
  contactSource  String             @default("organic") @map("contact_source")
  adSourceId     String?            @map("ad_source_id")
  adHeadline     String?            @map("ad_headline")
  adImageUrl     String?            @map("ad_image_url")
  createdAt      DateTime           @default(now()) @map("created_at")
  updatedAt      DateTime           @updatedAt @map("updated_at")

  tenant            Tenant              @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  contact           Contact             @relation(fields: [contactId], references: [id])
  assignedTo        User?               @relation("AssignedAgent", fields: [assignedToId], references: [id])
  channel           Channel?            @relation(fields: [channelId], references: [id], onDelete: SetNull)
  whatsappNumber    WhatsAppNumber?     @relation(fields: [whatsappNumberId], references: [id], onDelete: SetNull)
  messages          Message[]
  notes             ConversationNote[]
  activityLogs      ActivityLog[]
  pinnedMessages    PinnedMessage[]
  conversationEvents ConversationEvent[]

  @@index([tenantId])
  @@index([tenantId, status])
  @@index([tenantId, contactId])
  @@index([tenantId, assignedToId])
  @@index([tenantId, lastMessageAt])
  @@index([tenantId, status, lastMessageAt])
  @@index([tenantId, slaDeadline])
  @@map("conversations")
}

model ConversationEvent {
  id             String              @id @default(uuid())
  tenantId       String              @map("tenant_id")
  conversationId String              @map("conversation_id")
  actorId        String?             @map("actor_id")
  type           ConversationEventType
  payload        Json                @default("{}")
  createdAt      DateTime            @default(now()) @map("created_at")

  tenant       Tenant       @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  conversation Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)

  @@index([conversationId])
  @@index([tenantId, createdAt])
  @@map("conversation_events")
}

enum ConversationEventType {
  OPENED
  REQUESTED
  INTERVENED
  RESOLVED
  REOPENED
  ASSIGNED
  UNASSIGNED
  TRANSFERRED
  NOTE_ADDED
  TAG_ADDED
  TAG_REMOVED
  BOT_PAUSED
  BOT_RESUMED
  SLA_BREACHED
}

enum ConversationStatus {
  OPEN
  REQUESTED
  INTERVENED
  RESOLVED
  PENDING
  SNOOZED
}

model ConversationNote {
  id             String   @id @default(uuid())
  conversationId String   @map("conversation_id")
  authorId       String   @map("author_id")
  content        String
  createdAt      DateTime @default(now()) @map("created_at")

  conversation Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  author       User         @relation(fields: [authorId], references: [id])

  @@index([conversationId])
  @@map("conversation_notes")
}

model Message {
  id                String           @id @default(uuid())
  tenantId          String           @map("tenant_id")
  conversationId    String           @map("conversation_id")
  contactId         String           @map("contact_id")
  senderId          String?          @map("sender_id")
  replyToId         String?          @map("reply_to_id")
  whatsappMessageId String?          @map("whatsapp_message_id")
  direction         MessageDirection
  type              MessageType      @default(TEXT)
  status            MessageStatus    @default(QUEUED)
  content           String?
  mediaUrl          String?          @map("media_url")
  mediaType         String?          @map("media_type")
  mediaSize         Int?             @map("media_size")
  mediaCaption      String?          @map("media_caption")
  templateId        String?          @map("template_id")
  templateVariables Json?            @map("template_variables")
  metadata          Json?
  isStarred         Boolean          @default(false) @map("is_starred")
  isPinned          Boolean          @default(false) @map("is_pinned")
  isEdited          Boolean          @default(false) @map("is_edited")
  editedAt          DateTime?        @map("edited_at")
  deletedForEveryone Boolean         @default(false) @map("deleted_for_everyone")
  deletedAt         DateTime?        @map("deleted_at")
  sentAt            DateTime?        @map("sent_at")
  deliveredAt       DateTime?        @map("delivered_at")
  readAt            DateTime?        @map("read_at")
  failedAt          DateTime?        @map("failed_at")
  failureReason     String?          @map("failure_reason")
  createdAt         DateTime         @default(now()) @map("created_at")

  tenant       Tenant            @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  conversation Conversation      @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  contact      Contact           @relation(fields: [contactId], references: [id])
  sender       User?             @relation("MessageSender", fields: [senderId], references: [id])
  replyTo      Message?          @relation("MessageReplies", fields: [replyToId], references: [id])
  replies      Message[]         @relation("MessageReplies")
  reactions    MessageReaction[]
  pinnedIn     PinnedMessage[]
  editHistory      MessageEdit[]
  messageDeletions MessageDeletion[]

  @@unique([tenantId, whatsappMessageId])
  @@index([tenantId])
  @@index([conversationId])
  @@index([conversationId, createdAt])
  @@index([whatsappMessageId])
  @@index([tenantId, createdAt])
  @@index([tenantId, mediaUrl])
  @@map("messages")
}

model MessageEdit {
  id              String   @id @default(uuid())
  messageId       String   @map("message_id")
  tenantId        String   @map("tenant_id")
  previousContent String   @map("previous_content")
  editedById      String?  @map("edited_by_id")
  editedAt        DateTime @default(now()) @map("edited_at")

  message  Message @relation(fields: [messageId], references: [id], onDelete: Cascade)
  editedBy User?   @relation(fields: [editedById], references: [id], onDelete: SetNull)

  @@index([messageId])
  @@index([tenantId])
  @@map("message_edits")
}

model MessageDeletion {
  id        String   @id @default(uuid())
  messageId String   @map("message_id")
  userId    String   @map("user_id")
  tenantId  String   @map("tenant_id")
  deletedAt DateTime @default(now()) @map("deleted_at")

  message Message @relation(fields: [messageId], references: [id], onDelete: Cascade)
  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  tenant  Tenant  @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([messageId, userId])
  @@index([tenantId])
  @@index([userId])
  @@map("message_deletions")
}

enum MessageDirection {
  INBOUND
  OUTBOUND
}

enum MessageType {
  TEXT
  IMAGE
  VIDEO
  AUDIO
  DOCUMENT
  TEMPLATE
  INTERACTIVE
  LOCATION
  CONTACTS
  STICKER
  NOTE
}

enum MessageStatus {
  QUEUED
  SENT
  DELIVERED
  READ
  FAILED
}

model Channel {
  id          String      @id @default(uuid())
  tenantId    String      @map("tenant_id")
  type        ChannelType
  name        String
  isActive    Boolean     @default(true) @map("is_active")
  credentials Json        @default("{}") @map("credentials")
  metadata    Json        @default("{}") @map("metadata")
  createdAt   DateTime    @default(now()) @map("created_at")
  updatedAt   DateTime    @updatedAt @map("updated_at")

  tenant        Tenant         @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  conversations Conversation[]

  @@unique([tenantId, type, name])
  @@index([tenantId])
  @@map("channels")
}

enum ChannelType {
  WHATSAPP
  FACEBOOK_MESSENGER
  INSTAGRAM
  TELEGRAM
  EMAIL
  WEB_CHAT
  TIKTOK
  TWITTER
  LINKEDIN
}

model ActivityLog {
  id             String         @id @default(uuid())
  tenantId       String         @map("tenant_id")
  conversationId String?        @map("conversation_id")
  contactId      String?        @map("contact_id")
  userId         String?        @map("user_id")
  action         ActivityAction
  metadata       Json           @default("{}")
  createdAt      DateTime       @default(now()) @map("created_at")

  tenant       Tenant        @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  conversation Conversation? @relation(fields: [conversationId], references: [id], onDelete: SetNull)
  contact      Contact?      @relation(fields: [contactId], references: [id], onDelete: SetNull)
  user         User?         @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([tenantId, createdAt])
  @@index([conversationId])
  @@map("activity_logs")
}

enum ActivityAction {
  CONVERSATION_CREATED
  CONVERSATION_ASSIGNED
  CONVERSATION_UNASSIGNED
  CONVERSATION_REQUESTED
  CONVERSATION_INTERVENED
  CONVERSATION_RESOLVED
  CONVERSATION_REOPENED
  CONVERSATION_ARCHIVED
  CONVERSATION_TRANSFERRED
  MESSAGE_SENT
  MESSAGE_EDITED
  MESSAGE_DELETED
  MESSAGE_STARRED
  NOTE_ADDED
  NOTE_DELETED
  TAG_ADDED
  TAG_REMOVED
  CONTACT_UPDATED
  CONTACT_BLOCKED
  AUTOMATION_TRIGGERED
  CAMPAIGN_LAUNCHED
  SURVEY_RESPONSE
  CALL_ENDED
  CALL_INITIATED
  CALL_MISSED
  CALL_DECLINED
  CALL_CANCELED
}

model MessageReaction {
  id        String   @id @default(uuid())
  messageId String   @map("message_id")
  tenantId  String   @map("tenant_id")
  userId    String?  @map("user_id")
  emoji     String
  createdAt DateTime @default(now()) @map("created_at")

  message Message @relation(fields: [messageId], references: [id], onDelete: Cascade)
  tenant  Tenant  @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  user    User?   @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@unique([messageId, userId, emoji])
  @@index([messageId])
  @@map("message_reactions")
}

model PinnedMessage {
  id             String   @id @default(uuid())
  tenantId       String   @map("tenant_id")
  conversationId String   @map("conversation_id")
  messageId      String   @map("message_id")
  pinnedById     String   @map("pinned_by_id")
  pinnedAt       DateTime @default(now()) @map("pinned_at")

  tenant       Tenant       @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  conversation Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  message      Message      @relation(fields: [messageId], references: [id], onDelete: Cascade)
  pinnedBy     User         @relation("PinnedBy", fields: [pinnedById], references: [id])

  @@unique([conversationId, messageId])
  @@index([conversationId])
  @@map("pinned_messages")
}

model CallLog {
  id                String        @id @default(uuid())
  tenantId          String        @map("tenant_id")
  contactId         String?       @map("contact_id")
  userId            String?       @map("user_id")
  direction         CallDirection
  status            CallStatus
  duration          Int?
  phone             String?
  notes             String?
  metadata          Json          @default("{}")
  isArchived        Boolean       @default(false) @map("is_archived")
  endReason         String?       @map("end_reason")
  recordingUrl      String?       @map("recording_url")
  whatsappCallId    String?       @map("whatsapp_call_id")
  callLinkToken     String?       @unique @map("call_link_token")
  callLinkExpiresAt DateTime?     @map("call_link_expires_at")
  scheduledAt       DateTime?     @map("scheduled_at")
  startedAt         DateTime?     @map("started_at")
  answeredAt        DateTime?     @map("answered_at")
  endedAt           DateTime?     @map("ended_at")
  createdAt         DateTime      @default(now()) @map("created_at")
  updatedAt         DateTime      @updatedAt @map("updated_at")

  tenant    Tenant     @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  contact   Contact?   @relation(fields: [contactId], references: [id])
  user      User?      @relation(fields: [userId], references: [id], onDelete: SetNull)
  callNotes CallNote[]

  @@index([tenantId, createdAt])
  @@index([tenantId, contactId])
  @@index([tenantId, status])
  @@index([tenantId, isArchived])
  @@map("call_logs")
}

model CallNote {
  id        String   @id @default(uuid())
  callLogId String   @map("call_log_id")
  userId    String   @map("user_id")
  content   String

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  callLog CallLog @relation(fields: [callLogId], references: [id], onDelete: Cascade)
  user    User    @relation(fields: [userId], references: [id])

  @@index([callLogId])
  @@map("call_notes")
}

enum CallDirection {
  INCOMING
  OUTGOING
}

enum CallStatus {
  SCHEDULED
  INITIATED
  RINGING
  ONGOING
  MISSED
  DECLINED
  CANCELED
  UNANSWERED
  BUSY
  FAILED
  ENDED
  RECONNECTING
  HOLD
  VOICEMAIL
}

model Template {
  id              String           @id @default(uuid())
  tenantId        String           @map("tenant_id")
