# Copy to apps/backend/.env.test and point at a disposable Postgres database
# (never your dev or production DB -- e2e tests truncate tables between runs).
#
# Quick local option, reusing the dev Postgres container with a separate DB:
#   docker exec -it wa_postgres psql -U waplatform -c "CREATE DATABASE waplatform_test;"
#
# Then apply migrations once against it:
#   DATABASE_URL=postgresql://waplatform:PASSWORD@localhost:5432/waplatform_test pnpm --filter @whatsapp-platform/backend prisma:migrate

DATABASE_URL=postgresql://waplatform:CHANGE_ME@localhost:5432/waplatform_test
JWT_SECRET=test-jwt-secret-do-not-use-in-production
JWT_REFRESH_SECRET=test-jwt-refresh-secret-do-not-use-in-production
