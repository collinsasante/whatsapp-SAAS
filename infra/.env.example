# ============================================================
# WhatsApp Platform - Production Environment Variables
# Copy this to infra/.env and fill in your values
# ============================================================

# === DOMAIN ===
DOMAIN=yourdomain.com
FRONTEND_URL=https://yourdomain.com
PUBLIC_URL=https://yourdomain.com
NEXT_PUBLIC_API_URL=https://yourdomain.com/api/v1
NEXT_PUBLIC_SOCKET_URL=https://yourdomain.com

# === POSTGRESQL ===
POSTGRES_USER=waplatform
POSTGRES_PASSWORD=CHANGE_ME_STRONG_DB_PASSWORD_HERE
POSTGRES_DB=waplatform

# === REDIS ===
REDIS_PASSWORD=CHANGE_ME_STRONG_REDIS_PASSWORD_HERE

# === JWT SECRETS (generate with: openssl rand -base64 64) ===
JWT_SECRET=CHANGE_ME_64_CHAR_RANDOM_SECRET_HERE
JWT_REFRESH_SECRET=CHANGE_ME_DIFFERENT_64_CHAR_RANDOM_SECRET_HERE

# === STORAGE ===
# Options: 'local', 'minio', or 's3'
STORAGE_DRIVER=s3

# === AWS S3 ===
AWS_ACCESS_KEY_ID=CHANGE_ME_AWS_ACCESS_KEY_ID
AWS_SECRET_ACCESS_KEY=CHANGE_ME_AWS_SECRET_ACCESS_KEY
AWS_REGION=us-east-1
AWS_S3_BUCKET=your-bucket-name

# === MINIO (S3-compatible storage, used when STORAGE_DRIVER=minio) ===
MINIO_ACCESS_KEY=CHANGE_ME_MINIO_ACCESS_KEY
MINIO_SECRET_KEY=CHANGE_ME_STRONG_MINIO_SECRET_KEY
MINIO_BUCKET=whatsapp-platform

# === RATE LIMITING ===
THROTTLE_TTL=60000
THROTTLE_LIMIT=100

# === RESEND INBOUND WEBHOOK ===
RESEND_WEBHOOK_SECRET=whsec_your_signing_secret_here

# === BILLING: STRIPE (subscriptions + AI credits, charged in USD) ===
STRIPE_SECRET_KEY=sk_test_or_live_your_stripe_secret_key
STRIPE_PUBLISHABLE_KEY=pk_test_or_live_your_stripe_publishable_key
STRIPE_WEBHOOK_SECRET=whsec_your_stripe_webhook_signing_secret
# Webhook endpoint to register in the Stripe dashboard:
#   https://yourdomain.com/api/v1/billing/webhooks/stripe
# Events to subscribe to: invoice.payment_succeeded, invoice.payment_failed,
# customer.subscription.deleted, payment_intent.succeeded, payment_intent.payment_failed

# === BILLING: PAYSTACK (subscriptions + AI credits, charged in GHS) ===
PAYSTACK_SECRET_KEY=sk_test_or_live_your_paystack_secret_key
PAYSTACK_PUBLIC_KEY=pk_test_or_live_your_paystack_public_key
# Webhook endpoint to register in the Paystack dashboard:
#   https://yourdomain.com/api/v1/billing/webhooks/paystack
# Events: charge.success, charge.failed, subscription.disable

# After setting real keys above, provision matching Stripe Prices and Paystack
# Plans for every paid Plan row (set ghsMonthlyPrice/ghsYearlyPrice on each Plan
# first, since Paystack charges GHS here while Stripe charges USD):
#   pnpm --filter @whatsapp-platform/backend run billing:setup-plans
